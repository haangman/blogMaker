# Claude Code CLI 의존 — Anthropic API 키는 사용하지 않는다.
# 부팅 시 `claude --version`, `claude -p "ping"` 으로 인증 살아있는지 헬스체크.

# === 외부 API ===

# Unsplash (https://unsplash.com/developers — Access Key를 사용)
UNSPLASH_ACCESS_KEY=

# Pexels (https://www.pexels.com/api/) — Unsplash 폴백
PEXELS_API_KEY=

# Reddit — 인증 없이 .json 엔드포인트 호출. User-Agent만 정중하게.
REDDIT_USER_AGENT=blogmaker/0.1 (by /u/haangman)


# === 발행/Git ===

# J-Blog 리포 경로 (blogMaker 기준 상대경로 또는 절대경로)
JBLOG_PATH=../J-Blog

# git commit 시 작성자 정보 (시스템 git config가 비어 있을 때 폴백)
GIT_USER_NAME=
GIT_USER_EMAIL=


# === 동작 옵션 ===

LOG_LEVEL=INFO

# true면 글 생성·게이트는 돌지만 J-Blog로의 push는 스킵
DRY_RUN=false

# HuggingFace 모델 캐시 경로 — 첫 임베딩 모델 다운로드(약 470MB) 자리 고정
# 예: C:/Users/김은희/.cache/huggingface
HF_HOME=

# 하루에 자동 발행할 글 수의 상한
MAX_DAILY_ARTICLES=2


# === Claude CLI ===

# PATH에 claude가 있으면 그대로 'claude'. 아니면 절대경로(예: C:/Users/김은희/AppData/Local/Programs/claude/claude.exe)
CLAUDE_CLI_PATH=claude

# 단일 호출 타임아웃(초). 글 생성은 길어질 수 있어 넉넉히.
CLAUDE_CLI_TIMEOUT_SEC=180

# 한 사이클 내 LLM 호출 횟수 상한.
# 구독 quota 폭주 보호 (비용 가드 아님 — Claude CLI 구독 요금제 기준).
# 사이클 호출이 이 값을 넘으면 사이클을 중단한다.
MAX_LLM_CALLS_PER_CYCLE=80
